# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="your_token_here"
TELEGRAM_SECRET_TOKEN="change_me_to_a_random_string"

# ── Vision API ───────────────────────────────────────────────────────────────
VISION_API_URL=""
# Minimum confidence score (0.0–1.0) to accept Vision API results
VISION_MIN_CONFIDENCE="0.3"

# ── Google Tasks OAuth ───────────────────────────────────────────────────────
GOOGLE_TASKS_ACCESS_TOKEN=""
GOOGLE_TASKS_REFRESH_TOKEN=""
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_TOKEN_URL="https://oauth2.googleapis.com/token"
GOOGLE_TASKLIST_PROYECTOS_ID="@default"
GOOGLE_TASKLIST_JOKEM_ID="@default"
GOOGLE_TASKLIST_PERSONALES_ID="@default"
GOOGLE_TASKLIST_DOMESTICAS_ID="@default"

# ── Preview / admin ───────────────────────────────────────────────────────────
PREVIEW_EXPIRATION_MINUTES="60"
ADMIN_API_TOKEN=""

# ── HTTP / retry ─────────────────────────────────────────────────────────────
HTTP_RETRY_ATTEMPTS="3"
HTTP_RETRY_BACKOFF_SECONDS="0.25"
HTTP_TIMEOUT_SECONDS="8.0"

# ── Image preprocessing ───────────────────────────────────────────────────────
IMAGE_MAX_WIDTH="1024"
IMAGE_CONTRAST_FACTOR="2.0"

# ── Audio / Whisper (local faster-whisper, CPU) ───────────────────────────────
WHISPER_MODEL_SIZE="small"
WHISPER_LANGUAGE="es"
WHISPER_DEVICE="cpu"
# Set to true to swallow local Whisper errors and return empty transcript
WHISPER_FALLBACK_TO_API="false"

# ── Misc ──────────────────────────────────────────────────────────────────────
DEFAULT_TIMEZONE="America/Costa_Rica"
# Set to true ONLY in development/testing — enables the /webhook/test endpoint
ENABLE_TEST_ENDPOINT="false"

# ── Database ─────────────────────────────────────────────────────────────────
# Docker-compose uses /app/data/neuroboard.db (volume-mounted)
DATABASE_URL="sqlite:///./data/neuroboard.db"
